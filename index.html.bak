<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🐜 HormigasAIS | Protocolo LBH</title>
    <style>
        body { background: #0d1117; color: #58a6ff; font-family: 'Courier New', monospace; padding: 20px; line-height: 1.5; }
        .colonia { border: 1px solid #30363d; padding: 25px; border-radius: 8px; max-width: 850px; margin: auto; background: #161b22; }
        .tag { background: #238636; color: white; padding: 3px 10px; border-radius: 4px; font-size: 0.85em; font-weight: bold; }
        .feromona-log { color: #8b949e; font-size: 0.9em; margin-top: 25px; border-top: 1px solid #30363d; padding-top: 15px; height: 180px; overflow-y: hidden; }
        h1 { color: #f0f6fc; margin-bottom: 5px; }
        h2 { color: #79c0ff; font-size: 1.2em; border-bottom: 1px solid #30363d; padding-bottom: 10px; }
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin: 25px 0; }
        .card { border: 1px solid #30363d; padding: 15px; border-radius: 6px; background: #0d1117; }
        .status-dot { height: 10px; width: 10px; background-color: #238636; border-radius: 50%; display: inline-block; margin-right: 5px; }
        .links-authority { display: flex; gap: 15px; flex-wrap: wrap; margin-top: 20px; }
        .btn-auth { text-decoration: none; color: #d29922; border: 1px solid #d29922; padding: 5px 12px; border-radius: 4px; font-size: 0.8em; transition: 0.3s; }
        .btn-auth:hover { background: #d29922; color: #0d1117; }
    </style>
</head>
<body>
    <div class="colonia">
        <h1>🐜 HormigasAIS</h1>
        <p><span class="tag">Protocolo LBH v2.0</span> — Nodo A16-SanMiguel-SV</p>
        
        <div class="links-authority">
            <a href="https://zenodo.org/records/17767205" class="btn-auth" target="_blank">📜 DOI: 10.5281/zenodo.17767205</a>
            <a href="https://www.linkedin.com/in/cristhiam-lbh-architect/" class="btn-auth" target="_blank">👤 LinkedIn: CLHQ</a>
            <a href="https://github.com/HormigasAIS" class="btn-auth" target="_blank">📂 GitHub Colonia</a>
        </div>

        <hr style="border: 0; border-top: 1px solid #30363d; margin: 25px 0;">
        
        <h2>Inteligencia Colectiva Soberana</h2>
        <p>Red distribuida de nodos autónomos que emiten, validan y consensúan feromonas digitales usando el Protocolo LBH — sin servidores centrales.</p>
        <p style="font-size: 0.85em; color: #8b949e;">Operado desde El Salvador · Android A16 · Termux</p>

        <div class="grid">
            <div class="card">
                <div style="font-size: 0.8em; color: #8b949e;">CONSENSO COLONIA</div>
                <div style="font-size: 1.2em; font-weight: bold;"><span class="status-dot"></span>ACTIVO</div>
            </div>
            <div class="card">
                <div style="font-size: 0.8em; color: #8b949e;">TRUST PROMEDIO</div>
                <div style="font-size: 1.2em; font-weight: bold; color: #3fb950;">0.85</div>
            </div>
            <div class="card">
                <div style="font-size: 0.8em; color: #8b949e;">API STATUS</div>
                <div style="font-size: 0.9em; font-weight: bold;">api.hormigasais.com</div>
            </div>
        </div>

        <div class="feromona-log" id="logs">
            <span style="color: #d29922;">// Firma CLHQ validada. Sincronizando rastro...</span><br>
        </div>
        
        <p style="text-align: center; margin-top: 30px; font-size: 0.8em; color: #484f58;">
            © 2026 HormigasAIS · San Miguel, SV · Sovereign Infrastructure
        </p>
    </div>

    <script>
        const log = document.getElementById('logs');
        function emitirFeromona() {
            const now = new Date();
            const timestamp = (now.getTime() / 1000).toFixed(3);
            const pheromone = {
                ts: parseFloat(timestamp),
                type: "lbh_pulse",
                origin: "A16_Soberano",
                trust: 0.85,
                sig: "CLHQ-MASTER"
            };
            const entry = document.createElement('div');
            entry.innerHTML = `<span style="color: #3fb950;">[${now.toLocaleTimeString()}]</span> PHEROMONE: ${JSON.stringify(pheromone)}`;
            log.prepend(entry);
            if (log.childNodes.length > 8) log.removeChild(log.lastChild);
        }
        setInterval(emitirFeromona, 8000);
        emitirFeromona();
    </script>
</body>
</html>
